{
    "$schema":  "https://schema.freqtrade.io/schema.json",
    "max_open_trades":  1,
    "stake_currency":  "USDT",
    "stake_amount":  "unlimited",
    "tradable_balance_ratio":  0.40,
    "fiat_display_currency":  "USD",
    "dry_run":  true,
    "trading_mode":  "futures",
    "margin_mode":  "isolated",
    "unfilledtimeout":  {
                            "entry":  10,
                            "exit":  10,
                            "exit_timeout_count":  0,
                            "unit":  "minutes"
                        },
    "entry_pricing":  {
                          "price_side":  "same",
                          "use_order_book":  true,
                          "order_book_top":  1
                      },
    "exit_pricing":  {
                         "price_side":  "same",
                         "use_order_book":  true,
                         "order_book_top":  1
                     },
    "exchange":  {
                     "name":  "binance",
                     "key":  "",
                     "secret":  "",
                     "ccxt_config":  {
                                         "defaultType":  "future"
                                     },
                     "ccxt_async_config":  {
                                               "defaultType":  "future"
                                           },
                     "pair_whitelist":  [
                                            "ATOM/USDT:USDT"
                                        ],
                     "pair_blacklist":  [

                                        ]
                 },
    "pairlists":  [
                      {
                          "method":  "StaticPairList"
                      }
                  ],
    "telegram":  {
                     "enabled":  false,
                     "token":  "",
                     "chat_id":  ""
                 },
    "api_server":  {
                       "enabled":  false,
                       "listen_ip_address":  "127.0.0.1",
                       "listen_port":  8080,
                       "username":  "freqtrader",
                       "password":  "freqtrader",
                       "jwt_secret_key":  "somethingRandomSomethingRandom123"
                   },
    "bot_name":  "BacktestRunner",
    "initial_state":  "running"
}
